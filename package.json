{
  "name": "cucumber-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "tsx watch --env-file-if-exists=.env server/index.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "db:init": "tsx server/db/init.ts",
    "db:seed": "tsx server/db/seed.ts",
    "lint:2.5d": "tsx scripts/lint-2_5d.ts",
    "lint:luoxiaohei": "tsx scripts/lint-2_5d.ts --style luoxiaohei",
    "build:character": "tsx scripts/build-character-shape.ts",
    "check": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.167",
    "@hono/node-server": "^2.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "better-sqlite3": "^12.10.0",
    "hono": "^4.12.23",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.2",
    "tsx": "^4.20.0"
  }
}
